PORT=5000

# MongoDB Atlas connection string (add /api-studio before the ?)
MONGODB_URI=mongodb+srv://<user>:<pass>@cluster0.xxxxx.mongodb.net/api-studio?retryWrites=true&w=majority

PROXY_TIMEOUT_MS=15000

# Generate a strong random string for JWT signing
JWT_SECRET=change-this-to-a-long-random-secret

# From Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
